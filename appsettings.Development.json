{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "ConsumerGroupId": "inventory-service",
    "Topics": {
      "InventoryCommands": "inventory.commands",
      "InventoryReserved": "inventory.reserved",
      "InventoryReservationConfirmed": "inventory.reservation.confirmed",
      "InventoryReservationFailed": "inventory.reservation.failed",
      "InventoryReservationReleased": "inventory.reservation.released"
    }
  }
}
